# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Comma-separated Telegram numeric user IDs allowed to manage the bot
# Get yours from @userinfobot
ADMIN_IDS=123456789

# Download settings
# Max file size to send via Telegram bot API (50MB hard limit on standard Bot API)
MAX_FILE_SIZE_MB=48
DOWNLOAD_TIMEOUT_SECONDS=180

# Broadcast settings
BROADCAST_RATE_LIMIT=0.05
BROADCAST_BATCH_SIZE=25
