# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Comma-separated Telegram numeric user IDs allowed to manage the bot
# Get yours from @userinfobot
ADMIN_IDS=123456789

# ---------- Download settings ----------
# Max upload size sent through Telegram. Default 150 MB.
# Cloud Bot API: hard limit 50 MB.
# Local Bot API server: up to 2000 MB.
MAX_FILE_SIZE_MB=150

# Hard timeout for a single download (seconds)
DOWNLOAD_TIMEOUT_SECONDS=300

# ---------- Local Bot API server ----------
# Set true after installing the local telegram-bot-api server,
# logging the bot out from the cloud API, and starting the local one.
USE_LOCAL_API=false
LOCAL_API_BASE_URL=http://localhost:8081/bot
LOCAL_API_FILE_URL=http://localhost:8081/file/bot

# ---------- Broadcast settings ----------
BROADCAST_RATE_LIMIT=0.05
BROADCAST_BATCH_SIZE=25
