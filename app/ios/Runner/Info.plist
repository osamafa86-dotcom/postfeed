<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>ar</string>
	<key>CFBundleDisplayName</key>
	<string>فيد نيوز</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<!-- App uses only standard iOS encryption (HTTPS) — exempt from
	     the U.S. Export Administration Regulations annual filing.
	     Skipping this key forces App Store Connect to ask on every
	     build upload; declaring it here answers the question once. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>feedsnews</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<!-- iPhone: portrait only. The app's RTL layouts aren't tuned for
	     landscape and a reviewer rotating the device would see broken
	     compositions. iPad keeps both. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- Push notifications only. No persistent background audio. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>

	<!-- App Transport Security
	     - NSAllowsArbitraryLoads=false enforces HTTPS for all API calls
	       (api.feedsnews.net) and standard image sources.
	     - NSAllowsArbitraryLoadsForMedia=true permits cached image sources
	       from third-party news outlets (some legacy Arabic news sites still
	       serve over plain HTTP). flutter_html renders article bodies and
	       cached_network_image fetches thumbnails for over 30 syndicated
	       sources; without this key, articles with embedded HTTP media
	       would render as broken images. We do NOT load any non-media
	       content (HTML pages, JSON, scripts) over plain HTTP. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsArbitraryLoadsForMedia</key>
		<true/>
	</dict>

	<!-- Universal links are configured via Runner.entitlements
	     (applinks:feedsnews.net). No custom URL scheme is needed — the
	     unused `feedsnews://` scheme was removed to keep the binary
	     from advertising capabilities it doesn't use. -->

	<!-- Localized app name -->
	<key>CFBundleLocalizations</key>
	<array>
		<string>ar</string>
		<string>en</string>
	</array>
</dict>
</plist>
