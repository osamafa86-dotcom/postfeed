DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 301 legacy domain → canonical domain. Runs before the HTTPS rule so
    # old http://postfeed.emdatra.org/foo hits get a single hop straight
    # to https://feedsnews.net/foo, not a double redirect.
    RewriteCond %{HTTP_HOST} ^(www\.)?postfeed\.emdatra\.org$ [NC]
    RewriteRule ^(.*)$ https://feedsnews.net/$1 [R=301,L]

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Protect sensitive files
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^database\.sql$ - [F,L]
    RewriteRule ^cron_rss\.php$ - [F,L]
    RewriteRule ^deploy_log\.txt$ - [F,L]
    RewriteRule ^cron_log\.txt$ - [F,L]
    RewriteRule ^\.env$ - [F,L]
</IfModule>

AddDefaultCharset UTF-8

# Security Headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml application/rss+xml application/atom+xml application/xhtml+xml font/ttf font/otf
</IfModule>

# Browser caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 day"
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
    ExpiresByType text/javascript "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|jpg|jpeg|png|webp|gif|svg|ico|woff2|woff|ttf|otf)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
        Header unset ETag
    </FilesMatch>
    # Let proxies know responses vary by encoding
    Header append Vary Accept-Encoding
</IfModule>

# Disable ETag (rely on Cache-Control + Expires for caching)
FileETag None

# Friendly article URLs: /article/123 or /article/123/slug → article.php?id=123
<IfModule mod_rewrite.c>
    RewriteRule ^article/([0-9]+)(?:/[^/]*)?/?$ article.php?id=$1 [L,QSA]
    RewriteRule ^category/([a-z0-9-]+)/?$ category.php?slug=$1 [L,QSA]
    RewriteRule ^source/([0-9]+)/?$ source.php?id=$1 [L,QSA]
    RewriteRule ^topic/([^/]+)/?$ topic.php?slug=$1 [L,QSA]
    RewriteRule ^cluster/([a-f0-9]{40})/?$ cluster.php?key=$1 [L,QSA]
    RewriteRule ^timeline/([a-f0-9]{40})/?$ timeline.php?key=$1 [L,QSA]
    RewriteRule ^search/?$ search.php [L,QSA]
    RewriteRule ^timelines/?$ timelines.php [L,QSA]
    RewriteRule ^evolving-stories/network/?$ evolving-stories-network.php [L,QSA]
    RewriteRule ^evolving-stories/?$ evolving-stories.php [L,QSA]
    RewriteRule ^evolving-story/([^/]+)/quotes/?$ evolving-story-quotes.php?slug=$1 [L,QSA]
    RewriteRule ^evolving-story/([^/]+)/book/?$ evolving-story-book.php?slug=$1 [L,QSA]
    RewriteRule ^evolving-story/([^/]+)/?$ evolving-story.php?slug=$1 [L,QSA]
    RewriteRule ^trending/?$ trending.php [L,QSA]
    RewriteRule ^sabah/(\d{4}-\d{2}-\d{2})/?$ sabah.php?date=$1 [L,QSA]
    RewriteRule ^sabah/?$ sabah.php [L,QSA]
    RewriteRule ^gallery/(\d{4}-\d{2}-\d{2})/?$ gallery.php?date=$1 [L,QSA]
    RewriteRule ^gallery/?$ gallery.php [L,QSA]
    RewriteRule ^ask/?$ ask.php [L,QSA]
    # Weekly Rewind — latest digest, archive, and specific weeks.
    RewriteRule ^weekly/archive/?$ weekly.php?week=archive [L,QSA]
    RewriteRule ^weekly/(\d{4}-\d{1,2})/?$ weekly.php?week=$1 [L,QSA]
    RewriteRule ^weekly/?$ weekly.php [L,QSA]
    RewriteRule ^newsletter/confirm/([a-f0-9]{48})/?$ newsletter_confirm.php?token=$1 [L,QSA]
    RewriteRule ^newsletter/unsubscribe/([a-f0-9]{48})/?$ newsletter_unsubscribe.php?token=$1 [L,QSA]
    # Static info pages (Google News eligibility: About / Editorial / Corrections / Privacy / Contact)
    RewriteRule ^about/?$ about.php [L]
    RewriteRule ^privacy/?$ privacy.php [L]
    RewriteRule ^contact/?$ contact.php [L]
    RewriteRule ^editorial/?$ editorial.php [L]
    RewriteRule ^corrections/?$ corrections.php [L]
    RewriteRule ^rss\.xml$ rss.php [L]
    # IndexNow ownership-verification file: the protocol wants /{key}.txt
    # at the site root. We serve it dynamically from indexnow-key.php so
    # the key itself stays in /storage (not checked into git, not on the
    # webroot). The pattern is tight enough that normal *.txt requests
    # (robots.txt, ads.txt, etc.) don't get caught — key must be 8–128
    # hex chars.
    RewriteRule ^([a-f0-9]{8,128})\.txt$ indexnow-key.php?key=$1 [L,QSA]
</IfModule>
