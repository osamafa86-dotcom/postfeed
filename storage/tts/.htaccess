# Per-article TTS audio cache. These MP3s are served through
# /api/tts.php which adds auth, caching headers, and analytics
# hooks; the raw files should not be reachable directly.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
