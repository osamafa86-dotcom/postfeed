# Access control for /storage is pushed into each subdirectory so the
# public /storage/podcast/*.mp3 path works while /storage/cache and
# /storage/tts (internal caches) stay blocked. Putting a blanket
# "Deny from all" here broke podcast playback because nested rules
# don't reliably override it on every Apache build we've seen.
#
# But credentials that live directly in /storage (the FCM service
# account, OAuth token cache, secret key, IndexNow key) MUST never be
# served over HTTP. Deny them by name/extension here. This FilesMatch
# only touches dotfiles + .json/.txt/.pem/.p8/.key — podcast .mp3 files
# are unaffected, so playback keeps working.
<FilesMatch "(^\.|\.(json|txt|pem|p8|key|secret_key)$|fcm-service-account|fcm_token_cache)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
