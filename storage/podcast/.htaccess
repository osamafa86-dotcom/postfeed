# The parent /storage/.htaccess denies everything so internal caches
# (TTS per-article MP3s, AI response blobs) can't leak. Daily podcast
# MP3s, however, are meant to be public: they're embedded on /podcast
# and enumerated by the RSS feed. Allow just this directory through,
# restricted to MP3 files so nothing else ever gets served from here.
<FilesMatch "\.mp3$">
    # Apache 2.4+
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    # Apache 2.2 fallback
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Allow from all
    </IfModule>
</FilesMatch>
